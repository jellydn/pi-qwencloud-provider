{
  "name": "pi-qwencloud-provider",
  "version": "0.2.2",
  "description": "QwenCloud provider for pi — access Qwen3.8, DeepSeek V4, GLM-5.2, Wan image generation, and HappyHorse video generation through QwenCloud's OpenAI-compatible API",
  "keywords": [
    "ai",
    "dashscope",
    "deepseek",
    "glm",
    "happyhorse",
    "llm",
    "pi",
    "pi-coding-agent",
    "pi-package",
    "provider",
    "qwen",
    "qwencloud",
    "wan"
  ],
  "homepage": "https://github.com/jellydn/pi-qwencloud-provider#readme",
  "bugs": {
    "url": "https://github.com/jellydn/pi-qwencloud-provider/issues"
  },
  "license": "MIT",
  "author": "jellydn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jellydn/pi-qwencloud-provider.git"
  },
  "files": [
    "src",
    "tests",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bash tests/e2e/smoke.sh",
    "lint": "oxlint --config .oxlintrc.json src/ tests/",
    "format": "oxfmt --write src/ tests/",
    "format:check": "oxfmt --check src/ tests/",
    "typecheck": "tsc",
    "release": "bumpp --commit --push --tag",
    "release:patch": "bumpp --commit --push --tag patch",
    "release:minor": "bumpp --commit --push --tag minor",
    "release:major": "bumpp --commit --push --tag major",
    "pub": "npm publish"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.81.0",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^26.0.1",
    "bumpp": "^12.0.0",
    "np": "^12.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.71.0",
    "typescript": "^7.0.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=22"
  },
  "np": {
    "branch": "main",
    "testScript": "npm test",
    "yarn": false,
    "pnpm": false,
    "releaseDraft": true
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
